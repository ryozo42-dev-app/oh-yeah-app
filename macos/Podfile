platform :ios, '14.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  # 🔥 ここ追加
  pod 'BoringSSL-GRPC', '~> 0.0.24'
end

# 🔥 ここが超重要（全部潰す）
post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|

      # 🔥 iOSターゲット完全固定
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET[sdk=iphoneos*]'] = '14.0'
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET[sdk=iphonesimulator*]'] = '14.0'

      # 🔥 -G 完全削除（C）
      flags = config.build_settings['OTHER_CFLAGS']
      if flags
        if flags.is_a?(String)
          config.build_settings['OTHER_CFLAGS'] = flags.gsub('-G', '')
        elsif flags.is_a?(Array)
          config.build_settings['OTHER_CFLAGS'] = flags.reject { |f| f.include?('-G') }
        end
      end

      # 🔥 -G 完全削除（C++）
      cxxflags = config.build_settings['OTHER_CPLUSPLUSFLAGS']
      if cxxflags
        if cxxflags.is_a?(String)
          config.build_settings['OTHER_CPLUSPLUSFLAGS'] = cxxflags.gsub('-G', '')
        elsif cxxflags.is_a?(Array)
          config.build_settings['OTHER_CPLUSPLUSFLAGS'] = cxxflags.reject { |f| f.include?('-G') }
        end
      end

    end
  end
end